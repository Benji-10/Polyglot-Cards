# .env.example — copy to .env for local development with netlify dev
# Never commit .env to git

# Gemini AI API key — get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Neon Postgres connection string — get from https://neon.tech dashboard
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Netlify Identity is configured via Netlify dashboard — no env var needed locally
# but for local dev with netlify dev, it reads from your linked site automatically
